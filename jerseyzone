        // ============================================================
        // STATE
        // ============================================================
        let cart = [];
        let currentPage = 'home';

        // ============================================================
        // DOM REFS
        // ============================================================
        const pages = {
            home: document.getElementById('page-home'),
            club: document.getElementById('page-club'),
            national: document.getElementById('page-national'),
            classic: document.getElementById('page-classic'),
            shop: document.getElementById('page-shop'),
        };

        const navLinks = document.querySelectorAll('#mainNav a, #mobileNav a');
        const clubGrid = document.getElementById('clubGrid');
        const nationalGrid = document.getElementById('nationalGrid');
        const classicGrid = document.getElementById('classicGrid');
        const shopGrid = document.getElementById('shopGrid');
        const cartItems = document.getElementById('cartItems');
        const cartTotal = document.getElementById('cartTotal');
        const cartBadge = document.getElementById('cartBadge');
        const cartOverlay = document.getElementById('cartOverlay');
        const closeCart = document.getElementById('closeCart');
        const cartToggle = document.getElementById('cartToggle');
        const proceedCheckout = document.getElementById('proceedCheckout');
        const checkoutForm = document.getElementById('checkoutForm');
        const confirmOrderBtn = document.getElementById('confirmOrder');
        const toast = document.getElementById('toast');
        const logoHome = document.getElementById('logoHome');

        // ============================================================
        // UTILITY FUNCTIONS
        // ============================================================
        function showToast(msg, duration = 2500) {
            toast.textContent = msg;
            toast.classList.add('show');
            clearTimeout(toast._timer);
            toast._timer = setTimeout(() => toast.classList.remove('show'), duration);
        }

        function formatPrice(amount) {
            return amount + ' LYD';
        }

        function getProductsByCategory(cat) {
            return PRODUCTS.filter(p => p.category === cat);
        }

        function getProductsByTeam(team) {
            if (team === 'all') return PRODUCTS;
            return PRODUCTS.filter(p => p.team === team);
        }

        function getProductsByCategoryAndTeam(cat, team) {
            let filtered = PRODUCTS.filter(p => p.category === cat);
            if (team !== 'all') {
                filtered = filtered.filter(p => p.team === team);
            }
            return filtered;
        }

        // ============================================================
        // RENDER PRODUCTS
        // ============================================================
        function renderProducts(products, container) {
            if (!container) return;
            if (!products || products.length === 0) {
                container.innerHTML =
                    `<div style="grid-column:1/-1;padding:40px 0;color:rgba(255,255,255,0.2);text-align:center;font-size:1.1rem;">لا توجد منتجات</div>`;
                return;
            }

            container.innerHTML = products.map(p => `
                    <div class="glass-card product-card" data-id="${p.id}">
                        <div class="product-image">
                            <img src="${p.image}" alt="${p.name}" loading="lazy" />
                            ${p.badge ? `<span class="product-badge">${p.badge}</span>` : ''}
                        </div>
                        <div class="product-name">${p.name}</div>
                        <div class="product-team">${p.team}</div>
                        <div class="sizes">
                            ${p.sizes.map(s => `<span class="active">${s}</span>`).join('')}
                        </div>
                        <div class="product-price">${formatPrice(p.price)}</div>
                        <button class="btn-add" data-id="${p.id}">
                            <i class="fas fa-plus"></i> أضف للسلة
                        </button>
                    </div>
                `).join('');

            // Attach add to cart events
            container.querySelectorAll('.btn-add').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const id = parseInt(this.dataset.id);
                    addToCart(id);
                });
            });
        }

        // ============================================================
        // RENDER ALL SECTIONS
        // ============================================================
        function renderAllSections() {
            // Club page - all clubs initially
            renderProducts(getProductsByCategory('club'), clubGrid);

            // National page - all nationals initially
            renderProducts(getProductsByCategory('national'), nationalGrid);

            // Classic page - all classics initially
            renderProducts(getProductsByCategory('classic'), classicGrid);

            // Shop page - all products
            renderProducts(PRODUCTS, shopGrid);
        }

        // ============================================================
        // FILTER HANDLERS
        // ============================================================
        function setupFilters(filterContainer, grid, dataCategory) {
            const buttons = filterContainer.querySelectorAll('.filter-btn');
            buttons.forEach(btn => {
                btn.addEventListener('click', function() {
                    buttons.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');

                    const filter = this.dataset.filter;

                    let products;
                    if (dataCategory === 'all') {
                        // Shop page
                        if (filter === 'all') {
                            products = PRODUCTS;
                        } else {
                            products = getProductsByCategory(filter);
                        }
                    } else {
                        // Category pages with team filters
                        products = getProductsByCategoryAndTeam(dataCategory, filter);
                    }

                    renderProducts(products, grid);
                });
            });
        }

        // ============================================================
        // CART FUNCTIONS
        // ============================================================
        function addToCart(productId) {
            const product = PRODUCTS.find(p => p.id === productId);
            if (!product) return;

            const existing = cart.find(item => item.id === productId);
            if (existing) {
                existing.qty += 1;
                showToast(`🔄 تم تحديث كمية ${product.name}`);
            } else {
                cart.push({ ...product, qty: 1 });
                showToast(`✅ تم إضافة ${product.name} إلى السلة`);
            }
            updateCartUI();
        }

        function removeFromCart(productId) {
            cart = cart.filter(item => item.id !== productId);
            updateCartUI();
            showToast('🗑️ تم حذف المنتج من السلة');
        }

        function updateQuantity(productId, delta) {
            const item = cart.find(i => i.id === productId);
            if (!item) return;
            item.qty += delta;
            if (item.qty <= 0) {
                removeFromCart(productId);
                return;
            }
            updateCartUI();
        }

        function getCartTotal() {
            return cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
        }

        function getCartCount() {
            return cart.reduce((sum, item) => sum + item.qty, 0);
        }

        function updateCartUI() {
            const count = getCartCount();
            cartBadge.textContent = count;

            if (cart.length === 0) {
                cartItems.innerHTML =
                    `<div style="text-align:center;padding:30px 0;color:rgba(255,255,255,0.2);">🛒 سلة التسوق فارغة</div>`;
                cartTotal.textContent = '0 LYD';
                return;
            }

            cartItems.innerHTML = cart.map(item => `
                    <div class="cart-item">
                        <img src="${item.image}" alt="${item.name}" />
                        <div class="info">
                            <div class="name">${item.name}</div>
                            <div class="meta">${item.team} • ${item.sizes[0] || 'M'}</div>
                        </div>
                        <div class="qty-control">
                            <button onclick="updateQuantity(${item.id}, -1)">−</button>
                            <span>${item.qty}</span>
                            <button onclick="updateQuantity(${item.id}, 1)">+</button>
                        </div>
                        <div class="item-price">${formatPrice(item.price * item.qty)}</div>
                        <button class="remove-item" onclick="removeFromCart(${item.id})"><i class="fas fa-trash-alt"></i></button>
                    </div>
                `).join('');

            cartTotal.textContent = formatPrice(getCartTotal());
        }

        // ============================================================
        // WHATSAPP ORDER
        // ============================================================
        function generateWhatsAppMessage() {
            const name = document.getElementById('fullName').value.trim() || 'غير محدد';
            const phone = document.getElementById('phone').value.trim() || 'غير محدد';
            const altPhone = document.getElementById('altPhone').value.trim() || 'غير محدد';
            const city = document.getElementById('city').value.trim() || 'غير محدد';
            const area = document.getElementById('area').value.trim() || 'غير محدد';
            const address = document.getElementById('address').value.trim() || 'غير محدد';
            const notes = document.getElementById('notes').value.trim() || 'لا يوجد';

            let productsStr = cart.map(item =>
                `• ${item.name}\n  المقاس: ${item.sizes[0] || 'M'}\n  الكمية: ${item.qty}\n  السعر: ${formatPrice(item.price * item.qty)}`
            ).join('\n\n');

            const total = getCartTotal();

            return `🛒 *طلب جديد - JERSEY ZONE*%0A%0A👤 *الاسم:* ${name}%0A📱 *الهاتف:* ${phone}%0A📱 *هاتف بديل:* ${altPhone}%0A🏙️ *المدينة:* ${city}%0A📍 *المنطقة:* ${area}%0A🏠 *العنوان:* ${address}%0A📝 *ملاحظات:* ${notes}%0A%0A📦 *المنتجات:*%0A${productsStr}%0A%0A💰 *المجموع الكلي:* ${formatPrice(total)}%0A%0Aشكراً لتسوقكم من JERSEY ZONE! ❤️`;
        }

        function sendWhatsAppOrder() {
            const name = document.getElementById('fullName').value.trim();
            const phone = document.getElementById('phone').value.trim();
            const city = document.getElementById('city').value.trim();
            const address = document.getElementById('address').value.trim();

            if (!name || !phone || !city || !address) {
                showToast('⚠️ الرجاء ملء جميع الحقول المطلوبة');
                return;
            }

            if (cart.length === 0) {
                showToast('⚠️ سلة التسوق فارغة');
                return;
            }

            const msg = generateWhatsAppMessage();
            const url = `https://wa.me/2189156949?text=${msg}`;
            window.open(url, '_blank');
            showToast('✅ تم توجيهك إلى واتساب لإكمال الطلب');
        }

        // ============================================================
        // PAGE NAVIGATION
        // ============================================================
        function navigateTo(page) {
            // Hide all pages
            Object.keys(pages).forEach(key => {
                pages[key].classList.remove('active');
            });

            // Show target page
            if (pages[page]) {
                pages[page].classList.add('active');
            }

            // Update nav links
            document.querySelectorAll('#mainNav a, #mobileNav a').forEach(link => {
                link.classList.toggle('active', link.dataset.page === page);
            });

            currentPage = page;

            // Scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ============================================================
        // EVENT LISTENERS
        // ============================================================

        // Navigation
        document.querySelectorAll('#mainNav a, #mobileNav a').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const page = this.dataset.page;
                if (page) navigateTo(page);
            });
        });

        // Logo click -> home
        logoHome.addEventListener('click', () => navigateTo('home'));

        // Hero buttons
        document.getElementById('heroShopBtn').addEventListener('click', () => navigateTo('shop'));
        document.getElementById('heroExploreBtn').addEventListener('click', () => navigateTo('club'));

        // Cart toggle
        cartToggle.addEventListener('click', () => {
            cartOverlay.classList.add('open');
            updateCartUI();
            checkoutForm.classList.remove('open');
            document.getElementById('proceedCheckout').textContent = 'المتابعة إلى الدفع';
        });

        closeCart.addEventListener('click', () => {
            cartOverlay.classList.remove('open');
            checkoutForm.classList.remove('open');
            document.getElementById('proceedCheckout').textContent = 'المتابعة إلى الدفع';
        });

        cartOverlay.addEventListener('click', function(e) {
            if (e.target === this) {
                this.classList.remove('open');
                checkoutForm.classList.remove('open');
                document.getElementById('proceedCheckout').textContent = 'المتابعة إلى الدفع';
            }
        });

        // Proceed to checkout
        proceedCheckout.addEventListener('click', () => {
            if (cart.length === 0) {
                showToast('⚠️ سلة التسوق فارغة');
                return;
            }
            checkoutForm.classList.toggle('open');
            const btn = document.getElementById('proceedCheckout');
            if (checkoutForm.classList.contains('open')) {
                btn.textContent = 'إخفاء نموذج الدفع';
            } else {
                btn.textContent = 'المتابعة إلى الدفع';
            }
        });

        // Confirm order
        confirmOrderBtn.addEventListener('click', sendWhatsAppOrder);

        // Newsletter
        document.getElementById('newsBtn').addEventListener('click', () => {
            const email = document.getElementById('newsEmail').value.trim();
            if (!email || !email.includes('@')) {
                showToast('⚠️ الرجاء إدخال بريد إلكتروني صحيح');
                return;
            }
            showToast('✅ تم الاشتراك بنجاح!');
            document.getElementById('newsEmail').value = '';
        });

        // WhatsApp float
        document.getElementById('whatsappFloat').addEventListener('click', () => {
            window.open('https://wa.me/2189156949', '_blank');
        });

        // Admin badge
        document.getElementById('adminBadge').addEventListener('click', () => {
            showToast('🔐 لوحة الإدارة (قيد التطوير)');
        });

        // ============================================================
        // SETUP FILTERS
        // ============================================================
        setupFilters(document.getElementById('clubFilter'), clubGrid, 'club');
        setupFilters(document.getElementById('nationalFilter'), nationalGrid, 'national');
        setupFilters(document.getElementById('classicFilter'), classicGrid, 'classic');
        setupFilters(document.getElementById('shopFilter'), shopGrid, 'all');

        // ============================================================
        // INIT
        // ============================================================
        renderAllSections();
        updateCartUI();
        navigateTo('home');

        // Make functions globally accessible for inline onclick
        window.addToCart = addToCart;
        window.removeFromCart = removeFromCart;
        window.updateQuantity = updateQuantity;
        window.sendWhatsAppOrder = sendWhatsAppOrder;

        console.log('🚀 JERSEY ZONE • عيش شغفك، البس هويتك');
        console.log('📦 منتجات جاهزة:', PRODUCTS.length);
