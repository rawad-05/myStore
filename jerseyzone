<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JERSEY ZONE • عيش شغفك، البس هويتك</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800;900&display=swap" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        /* ============================================================
                   RESET & BASE
                   ============================================================ */
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --neon-purple: #A020F0;
            --electric-purple: #8A2BE2;
            --deep-purple: #4B0082;
            --dark-bg: #0A0714;
            --black: #050505;
            --white: #FFFFFF;
            --glass-bg: rgba(10, 7, 20, 0.7);
            --glass-border: rgba(160, 32, 240, 0.15);
            --font: 'Cairo', sans-serif;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font);
            background: var(--dark-bg);
            color: var(--white);
            line-height: 1.6;
            overflow-x: hidden;
            min-height: 100vh;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: var(--dark-bg);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--neon-purple);
            border-radius: 20px;
        }

        a {
            text-decoration: none;
            color: inherit;
        }
        button {
            cursor: pointer;
            font-family: inherit;
            border: none;
            outline: none;
        }
        input,
        select,
        textarea {
            font-family: inherit;
            outline: none;
            border: none;
        }

        /* ============================================================
                   GLASSMORPHISM
                   ============================================================ */
        .glass {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
        }

        .glass-card {
            background: rgba(20, 12, 40, 0.5);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(160, 32, 240, 0.12);
            transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            border-radius: 20px;
            padding: 16px 16px 20px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .glass-card:hover {
            border-color: var(--neon-purple);
            transform: translateY(-6px);
            box-shadow: 0 20px 50px rgba(160, 32, 240, 0.2);
        }

        /* ============================================================
                   GLOW & GRADIENTS
                   ============================================================ */
        .glow-purple {
            box-shadow: 0 0 30px rgba(160, 32, 240, 0.3);
        }
        .glow-purple-hover:hover {
            box-shadow: 0 0 50px rgba(160, 32, 240, 0.5);
            transition: 0.4s;
        }

        .text-gradient {
            background: linear-gradient(135deg, var(--neon-purple), var(--electric-purple), var(--deep-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .text-gradient-white {
            background: linear-gradient(135deg, #fff 30%, var(--neon-purple) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* ============================================================
                   BUTTONS
                   ============================================================ */
        .btn-primary {
            background: linear-gradient(135deg, var(--neon-purple), var(--electric-purple));
            color: #fff;
            font-weight: 700;
            padding: 14px 36px;
            border-radius: 60px;
            transition: all 0.35s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 1rem;
            border: none;
            box-shadow: 0 4px 20px rgba(160, 32, 240, 0.3);
        }

        .btn-primary:hover {
            transform: scale(1.04);
            box-shadow: 0 8px 40px rgba(160, 32, 240, 0.5);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid var(--neon-purple);
            color: #fff;
            font-weight: 600;
            padding: 12px 30px;
            border-radius: 60px;
            transition: all 0.35s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 1rem;
        }

        .btn-outline:hover {
            background: var(--neon-purple);
            box-shadow: 0 0 35px rgba(160, 32, 240, 0.4);
        }

        .btn-small {
            padding: 8px 20px;
            font-size: 0.85rem;
        }

        .btn-add {
            width: 100%;
            padding: 10px;
            border-radius: 40px;
            background: rgba(160, 32, 240, 0.12);
            color: #fff;
            font-weight: 600;
            font-size: 0.9rem;
            transition: 0.35s;
            border: 1px solid rgba(160, 32, 240, 0.2);
        }

        .btn-add:hover {
            background: var(--neon-purple);
            box-shadow: 0 0 30px rgba(160, 32, 240, 0.3);
            border-color: var(--neon-purple);
        }

        /* ============================================================
                   HEADER
                   ============================================================ */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 12px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(10, 7, 20, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(160, 32, 240, 0.1);
        }

        .header .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

        .header .logo-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--neon-purple), var(--deep-purple));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 1rem;
            color: #fff;
            box-shadow: 0 0 30px rgba(160, 32, 240, 0.2);
        }

        .header .logo-text {
            font-size: 1.2rem;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .header .logo-text span {
            background: linear-gradient(135deg, var(--neon-purple), var(--electric-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .header nav {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .header nav a {
            font-size: 0.85rem;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.5);
            transition: 0.3s;
            padding: 6px 14px;
            border-radius: 40px;
            position: relative;
        }

        .header nav a:hover,
        .header nav a.active {
            color: #fff;
            background: rgba(160, 32, 240, 0.1);
        }

        .header nav a.active {
            color: var(--neon-purple);
            background: rgba(160, 32, 240, 0.15);
        }

        .header .actions {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .header .actions .icon-btn {
            color: rgba(255, 255, 255, 0.5);
            font-size: 1.2rem;
            transition: 0.3s;
            position: relative;
            cursor: pointer;
            background: none;
            border: none;
            padding: 4px;
        }

        .header .actions .icon-btn:hover {
            color: var(--neon-purple);
        }

        .cart-badge {
            position: absolute;
            top: -6px;
            right: -8px;
            background: var(--neon-purple);
            color: #fff;
            font-size: 0.55rem;
            font-weight: 700;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 15px rgba(160, 32, 240, 0.4);
        }

        /* ============================================================
                   PAGES (show/hide)
                   ============================================================ */
        .page {
            display: none;
            padding-top: 80px;
            min-height: 100vh;
        }

        .page.active {
            display: block;
            animation: fadeIn 0.4s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ============================================================
                   HERO
                   ============================================================ */
        .hero {
            padding: 40px 24px 60px;
            max-width: 1400px;
            margin: 0 auto;
            position: relative;
            overflow: hidden;
        }

        .hero .hero-bg-glow {
            position: absolute;
            top: -200px;
            right: -200px;
            width: 700px;
            height: 700px;
            background: radial-gradient(circle, rgba(160, 32, 240, 0.1) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        .hero .hero-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
            position: relative;
            z-index: 1;
        }

        .hero .hero-content h1 {
            font-size: 3.5rem;
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 16px;
        }

        .hero .hero-content h1 .highlight {
            background: linear-gradient(135deg, var(--neon-purple), #c084fc, var(--electric-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero .hero-content p {
            font-size: 1.1rem;
            color: rgba(255, 255, 255, 0.5);
            max-width: 480px;
            margin-bottom: 32px;
            line-height: 1.8;
        }

        .hero .hero-content .cta-group {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .hero .hero-visual {
            display: flex;
            justify-content: center;
            position: relative;
        }

        .hero .hero-visual .hero-ring {
            width: 380px;
            height: 380px;
            border-radius: 50%;
            background: radial-gradient(circle at 30% 30%, rgba(160, 32, 240, 0.12), transparent 70%);
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border: 1px solid rgba(160, 32, 240, 0.08);
            animation: pulse-ring 4s ease-in-out infinite;
        }

        @keyframes pulse-ring {
            0%,
            100% {
                transform: translate(-50%, -50%) scale(1);
                opacity: 0.6;
            }
            50% {
                transform: translate(-50%, -50%) scale(1.08);
                opacity: 1;
            }
        }

        .hero .hero-visual .hero-jersey {
            width: 300px;
            height: auto;
            position: relative;
            z-index: 2;
            filter: drop-shadow(0 20px 60px rgba(160, 32, 240, 0.2));
        }

        .hero .hero-visual .hero-jersey img {
            width: 100%;
            height: auto;
            display: block;
            border-radius: 20px;
        }

        /* ============================================================
                   SECTION TITLES
                   ============================================================ */
        .section-title {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 4px;
        }

        .section-sub {
            color: rgba(255, 255, 255, 0.35);
            font-size: 0.95rem;
            margin-bottom: 28px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .section-header .view-all {
            color: var(--neon-purple);
            font-weight: 600;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: 0.3s;
            cursor: pointer;
        }

        .section-header .view-all:hover {
            gap: 12px;
            color: #c084fc;
        }

        /* ============================================================
                   PRODUCT GRID
                   ============================================================ */
        .section-wrap {
            padding: 20px 24px 40px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
            gap: 20px;
        }

        .product-card .product-image {
            width: 100%;
            aspect-ratio: 1/1;
            border-radius: 16px;
            overflow: hidden;
            background: rgba(20, 12, 40, 0.6);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 12px;
            position: relative;
            transition: 0.4s;
        }

        .product-card .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.5s;
        }

        .product-card:hover .product-image img {
            transform: scale(1.05);
        }

        .product-card .product-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: linear-gradient(135deg, var(--neon-purple), var(--deep-purple));
            color: #fff;
            font-size: 0.6rem;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 40px;
            letter-spacing: 0.3px;
            box-shadow: 0 4px 20px rgba(160, 32, 240, 0.2);
        }

        .product-card .product-name {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .product-card .product-team {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.35);
            margin-bottom: 6px;
        }

        .product-card .product-price {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--neon-purple);
            margin-bottom: 10px;
        }

        .product-card .product-price .currency {
            font-size: 0.7rem;
            font-weight: 400;
            color: rgba(255, 255, 255, 0.4);
        }

        .product-card .sizes {
            display: flex;
            gap: 5px;
            justify-content: center;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }

        .product-card .sizes span {
            font-size: 0.65rem;
            padding: 2px 10px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: rgba(255, 255, 255, 0.4);
            font-weight: 600;
        }

        .product-card .sizes span.active {
            border-color: var(--neon-purple);
            color: #fff;
            background: rgba(160, 32, 240, 0.12);
        }

        /* ============================================================
                   CATEGORY FILTER
                   ============================================================ */
        .filter-bar {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 28px;
            padding-bottom: 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }

        .filter-bar .filter-btn {
            padding: 8px 22px;
            border-radius: 40px;
            background: rgba(255, 255, 255, 0.03);
            color: rgba(255, 255, 255, 0.4);
            font-weight: 600;
            font-size: 0.85rem;
            transition: 0.3s;
            cursor: pointer;
            border: 1px solid transparent;
        }

        .filter-bar .filter-btn:hover {
            color: #fff;
            background: rgba(160, 32, 240, 0.06);
        }

        .filter-bar .filter-btn.active {
            background: rgba(160, 32, 240, 0.12);
            color: #fff;
            border-color: var(--neon-purple);
        }

        /* ============================================================
                   WHY US
                   ============================================================ */
        .why-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 16px;
            margin-top: 16px;
        }

        .why-card {
            padding: 24px 16px;
            border-radius: 20px;
            text-align: center;
            background: rgba(20, 12, 40, 0.3);
            border: 1px solid rgba(160, 32, 240, 0.06);
            transition: 0.4s;
        }

        .why-card:hover {
            border-color: var(--neon-purple);
            transform: translateY(-4px);
            box-shadow: 0 12px 40px rgba(160, 32, 240, 0.08);
        }

        .why-card .icon {
            font-size: 2rem;
            color: var(--neon-purple);
            margin-bottom: 10px;
        }

        .why-card h4 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .why-card p {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.35);
        }

        /* ============================================================
                   NEWSLETTER
                   ============================================================ */
        .newsletter-section {
            padding: 20px 24px 40px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .newsletter-box {
            border-radius: 28px;
            padding: 40px 32px;
            text-align: center;
            background: rgba(20, 12, 40, 0.3);
            border: 1px solid rgba(160, 32, 240, 0.06);
        }

        .newsletter-box h3 {
            font-size: 1.6rem;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .newsletter-box p {
            color: rgba(255, 255, 255, 0.35);
            margin-bottom: 20px;
        }

        .newsletter-box .news-form {
            display: flex;
            gap: 12px;
            max-width: 480px;
            margin: 0 auto;
            flex-wrap: wrap;
            justify-content: center;
        }

        .newsletter-box .news-form input {
            flex: 1;
            min-width: 200px;
            padding: 12px 20px;
            border-radius: 60px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: #fff;
            font-size: 0.9rem;
        }

        .newsletter-box .news-form input:focus {
            border-color: var(--neon-purple);
        }

        /* ============================================================
                   CART OVERLAY
                   ============================================================ */
        .cart-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 2000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .cart-overlay.open {
            display: flex;
        }

        .cart-panel {
            background: #120c1e;
            border: 1px solid rgba(160, 32, 240, 0.15);
            border-radius: 28px;
            max-width: 860px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            padding: 28px 32px;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.8);
            position: relative;
        }

        .cart-panel .close-cart {
            position: absolute;
            top: 14px;
            left: 20px;
            font-size: 1.4rem;
            color: rgba(255, 255, 255, 0.3);
            cursor: pointer;
            transition: 0.3s;
            background: none;
            border: none;
        }

        .cart-panel .close-cart:hover {
            color: #fff;
            transform: rotate(90deg);
        }

        .cart-panel h2 {
            font-size: 1.6rem;
            font-weight: 800;
            margin-bottom: 20px;
            text-align: center;
        }

        .cart-panel .cart-items {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 20px;
        }

        .cart-panel .cart-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 10px 14px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 14px;
            border: 1px solid rgba(255, 255, 255, 0.04);
        }

        .cart-panel .cart-item img {
            width: 56px;
            height: 56px;
            border-radius: 10px;
            object-fit: cover;
            background: rgba(20, 12, 40, 0.6);
        }

        .cart-panel .cart-item .info {
            flex: 1;
        }

        .cart-panel .cart-item .info .name {
            font-weight: 600;
            font-size: 0.95rem;
        }

        .cart-panel .cart-item .info .meta {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.3);
        }

        .cart-panel .cart-item .qty-control {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .cart-panel .cart-item .qty-control button {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(160, 32, 240, 0.1);
            color: #fff;
            font-size: 0.9rem;
            transition: 0.3s;
            border: 1px solid rgba(160, 32, 240, 0.1);
        }

        .cart-panel .cart-item .qty-control button:hover {
            background: var(--neon-purple);
        }

        .cart-panel .cart-item .qty-control span {
            font-weight: 600;
            min-width: 20px;
            text-align: center;
        }

        .cart-panel .cart-item .item-price {
            font-weight: 700;
            color: var(--neon-purple);
            min-width: 70px;
            text-align: left;
            font-size: 0.95rem;
        }

        .cart-panel .cart-item .remove-item {
            color: rgba(255, 255, 255, 0.15);
            cursor: pointer;
            transition: 0.3s;
            background: none;
            border: none;
            font-size: 0.9rem;
        }

        .cart-panel .cart-item .remove-item:hover {
            color: #ff4757;
        }

        .cart-panel .cart-total {
            display: flex;
            justify-content: space-between;
            padding: 14px 0;
            border-top: 1px solid rgba(160, 32, 240, 0.1);
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 16px;
        }

        .cart-panel .cart-total .total-price {
            color: var(--neon-purple);
            font-size: 1.3rem;
        }

        .cart-panel .checkout-btn {
            width: 100%;
            padding: 14px;
            border-radius: 60px;
            background: linear-gradient(135deg, var(--neon-purple), var(--electric-purple));
            color: #fff;
            font-weight: 700;
            font-size: 1rem;
            transition: 0.35s;
            box-shadow: 0 4px 30px rgba(160, 32, 240, 0.2);
        }

        .cart-panel .checkout-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 8px 50px rgba(160, 32, 240, 0.4);
        }

        /* ============================================================
                   CHECKOUT FORM
                   ============================================================ */
        .checkout-form {
            display: none;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid rgba(160, 32, 240, 0.08);
        }

        .checkout-form.open {
            display: block;
        }

        .checkout-form .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .checkout-form .form-group {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .checkout-form .form-group.full {
            grid-column: 1 / -1;
        }

        .checkout-form .form-group label {
            font-size: 0.75rem;
